{
  "name": "echospace",
  "version": "0.1.0-alpha.3",
  "type": "module",
  "description": "Open-source, local-first prompt debugging workspace for LLM developers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stonexer/echospace.git"
  },
  "homepage": "https://github.com/stonexer/echospace",
  "bugs": "https://github.com/stonexer/echospace/issues",
  "keywords": [
    "llm",
    "prompt",
    "debugging",
    "openai",
    "anthropic",
    "gemini",
    "chatgpt",
    "claude",
    "ai",
    "developer-tools"
  ],
  "bin": {
    "echospace": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./core/echo": {
      "import": "./dist/core/echo/index.js",
      "types": "./dist/core/echo/index.d.ts"
    },
    "./core/smart-paste": {
      "import": "./dist/core/smart-paste/index.js",
      "types": "./dist/core/smart-paste/index.d.ts"
    },
    "./core/providers": {
      "import": "./dist/core/providers/index.js",
      "types": "./dist/core/providers/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts . -p 3240 --no-open & vite --clearScreen false; kill $!",
    "dev:client": "vite",
    "dev:server": "tsx watch src/cli/index.ts . -p 3240 --no-open",
    "build": "vite build && tsup",
    "preview": "vite preview",
    "start": "node dist/cli/index.js",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@hono/node-server": "^1.13.8",
    "commander": "^13.1.0",
    "geist": "^1.7.0",
    "get-port": "^7.1.0",
    "hono": "^4.7.4",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.1.2",
    "open": "^10.1.2"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/language-data": "^6.5.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@tailwindcss/vite": "^4.1.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@uiw/react-codemirror": "^4.23.7",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^2.1.7",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.3",
    "tiktoken": "^1.0.18",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "vitest": "^4.0.18",
    "zustand": "^5.0.3"
  }
}
